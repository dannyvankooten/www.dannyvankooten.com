<style>
footer {
  padding: 1.5rem 1.5rem 0;
  margin: 3rem -1.5rem 0 -1.5rem;
  border-top: 1px solid #27272a;
  font-size: 0.9rem;
  color: #999;
}
.footer-links {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 1rem;
}
.copyright {
  margin-right: 0.5rem;
}
.footer-nav {
  display: flex;
  gap: 1rem;
}
.footer-nav a {
  color: #a1a1aa;
  text-decoration: none;
  transition: color 0.15s ease;
}
.footer-nav a:hover,
.footer-nav a:focus {
  color: #fafafa;
}
.social-links {
  display: flex;
  gap: 0.25rem;
}
.social-links a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 2rem;
  height: 2rem;
  color: #a1a1aa;
  text-decoration: none;
  transition: color 0.15s ease, background 0.15s ease;
  border-radius: 6px;
}
.social-links a:hover,
.social-links a:focus {
  color: #fafafa;
  background: #18181b;
}
@media (min-width: 576px) {
  footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer-links {
    margin-bottom: 0;
  }
}
</style>