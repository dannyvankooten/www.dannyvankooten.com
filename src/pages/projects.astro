---
import Layout from '../layouts/Layout.astro';

interface Project {
  name: string;
  description: string;
  repo?: string;
  website?: string;
  blog?: string;
}

const projects: Project[] = [
  { name: "Mailchimp for WordPress", description: "A WordPress plugin that allows you to tightly integrate your site with your Mailchimp account. The plugin grew to well over 100.000 active users in its first year, after which I built a paid version from <a href=\"/blog/2013/100-000-plugin-downloads-6-months-mailchimp-wordpress/\">a hospital bed in Vietnam</a> which turned into a huge success. It has been downloaded well over 52 million times and is in active use on over 2 million websites.", repo: "ibericode/mailchimp-for-wordpress", website: "https://www.mc4wp.com/", blog: "/blog/2013/my-newest-wordpress-plugin-mailchimp-for-wp/" },
  { name: "Koko Analytics", description: "Open-source and privacy friendly analytics plugin for WordPress that only tracks aggregated counts and keeps all data locally on the website's server. Currently in active use on about 50.000 websites.", repo: "ibericode/koko-analytics", website: "https://www.kokoanalytics.com/", blog: "/blog/2019/introducing-koko-analytics/" },
  { name: "HTML Forms", description: "A WordPress plugin to create multipurpose forms and handle form submissions in a safe and extendible way. I grew this plugin to a healthy ~9.000 active users before selling it in early 2024.", website: "https://htmlformsplugin.com" },
  { name: "Fathom Analytics", description: "Open-source and privacy friendly analytics. I <a href=\"/blog/2019/stepping-down-fathom-maintainer/\">stepped away from Fathom</a> in 2019 as its success at the time was hard to combine with 2 young children, but the project is still going strong (although no longer open-source) and has turned into a flourishing business.", repo: "usefathom/fathom", website: "https://usefathom.com/", blog: "/blog/2018/reviving-ana-as-fathom/" },
  { name: "Gozer", description: "A static site generator in Go with a focus on performance and simplicity.", repo: "dannyvankooten/gozer" },
  { name: "Nederlang", description: "An interpreted programming language with a bytecode compiler and stack-based virtual machine hosted in Rust.", repo: "dannyvankooten/nederlang", blog: "https://www.dannyvankooten.com/blog/2022/rewriting-interpreter-rust/" },
  { name: "Monkey-C", description: "An interpreted programming language hosted in C. This was my result of going through the wonderful <a href=\"https://interpreterbook.com/\">interpreter book</a> by Thorsten Ball.", repo: "dannyvankooten/monkey-c-monkey-do", blog: "/blog/2020/writing-an-interpreter-compiler/" },
  { name: "Browserpass", description: "A browser extension for <a href=\"https://www.passwordstore.org/\">Pass</a>, the unix password manager. I started hacking on this as I wanted to give <a href=\"https://developer.mozilla.org/en-US/docs/Mozilla/Add-ons/WebExtensions/Native_messaging\">native messaging</a> a try, which was pretty new at the time.", repo: "browserpass/browserpass-legacy", blog: "/blog/2016/chrome-extension-for-pass/" },
  { name: "ibericode/vat", description: "A PHP library for dealing with European VAT rules.", repo: "ibericode/vat" },
  { name: "AltoRouter", description: "A flexible routing class for PHP projects. My very first open-source project.", repo: "dannyvankooten/AltoRouter", website: "https://altorouter.com/", blog: "/blog/2012/altorouter-php-routing-class/" },
];

// Fetch GitHub stars for all projects with a repo
const token = import.meta.env.GITHUB_ACCESS_TOKEN;
const stars = new Map<string, number>();
if (token) {
  await Promise.all(projects.filter(p => p.repo).map(async (p) => {
    const res = await fetch(`https://api.github.com/repos/${p.repo}`, {
      headers: {
        'Authorization': `Bearer ${token}`,
        'Accept': 'application/vnd.github+json',
        'X-GitHub-Api-Version': '2022-11-28',
      },
    });
    if (res.ok) {
      const data = await res.json();
      stars.set(p.repo!, data.stargazers_count);
    }
  }));
}
---
<Layout title="Projects">
  <main class="content">
    <h1>Projects</h1>
    <p>I've been building and shipping open-source software for well over a decade. Here are some of the projects I'm most proud of.</p>

    <h2>Featured</h2>
    <p>These two WordPress plugins are my main products, actively maintained and used on millions of websites worldwide.</p>
    <div class="featured-projects">
      <a href="https://www.mc4wp.com/" class="featured-project">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 64 64" role="img" aria-label="Mailchimp for WordPress"><circle cx="32" cy="32" r="32" style="fill:#c44"/><path d="M16 47.325c-.03-.093-.175-1.23-.323-2.529-.562-4.936-2.305-9.96-5.202-14.994-.973-1.692-.959-1.751.663-2.684a48.828 48.828 0 0 0 3.038-1.92c1.29-.904 1.487-.822 3.033 1.263 1.28 1.725 1.732 1.999 1.998 1.209.408-1.21 4.748-4.45 5.961-4.45.465 0 1.603 1.364 2.529 3.032.926 1.669 1.853 3.034 2.06 3.035.58.002 1.226-5.916.808-7.413-.293-1.054.213-1.75 2.448-3.363 1.55-1.119 3.016-2.034 3.26-2.034.243 0 2.673 3.413 5.4 7.585 2.726 4.172 6.744 9.862 8.927 12.643l3.969 5.057-2.073 2.191c-1.14 1.206-2.43 2.192-2.864 2.192-1.383 0-5.331-4.39-9-10.007-1.954-2.993-3.753-5.455-3.997-5.471-.244-.017-.444 2.52-.444 5.637v5.667l-2.623 1.75c-1.442.962-2.841 1.748-3.109 1.747-.268-.001-1.285-1.687-2.26-3.746-.976-2.06-2.343-4.352-3.037-5.094l-1.263-1.35-.401 1.893c-1.385 6.524-1.593 6.986-3.904 8.646-2.045 1.47-3.42 2.047-3.594 1.508Z" style="fill:#fff"/></svg>
        <div>
          <strong>Mailchimp for WordPress</strong>
          <span>The #1 Mailchimp plugin for WordPress. 73M+ downloads, 2M+ active installs.</span>
        </div>
      </a>
      <a href="https://www.kokoanalytics.com/" class="featured-project">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 64 64" role="img" aria-label="Koko Analytics"><circle cx="32" cy="32" r="32" shape-rendering="geometricPrecision" style="fill:#b60205"/><path d="M48.42 20.641a.6.6 0 0 0-.66.15L31.984 37.736l-7.36-7.36a.6.6 0 0 0-.848 0l-8.4 8.4a.6.6 0 0 0-.176.424v3.6a.6.6 0 0 0 .6.6h32.4a.6.6 0 0 0 .6-.6V21.2a.6.6 0 0 0-.38-.559z" style="fill:#fff"/><path d="M48.42 20.641a.6.6 0 0 0-.66.15L31.984 37.736l5.664 5.664H48.2a.6.6 0 0 0 .6-.6V21.2a.6.6 0 0 0-.38-.559z" style="fill:#fff"/></svg>
        <div>
          <strong>Koko Analytics</strong>
          <span>Privacy-friendly analytics for WordPress. Open-source, GDPR compliant, fast.</span>
        </div>
      </a>
    </div>

    <h2>All projects</h2>
    <p>A more extensive list of projects I worked on over the years, ranging from WordPress plugins and web analytics to toy programming languages and browser extensions.</p>

    <div class="project-list">
      {projects.map(p => (
        <div class="project-card">
          <div class="project-header">
            <h4>{p.name}</h4>
            {p.repo && stars.has(p.repo) && (
              <span class="project-stars">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z"/></svg>
                {stars.get(p.repo)!.toLocaleString()}
              </span>
            )}
          </div>
          <p><Fragment set:html={p.description} /></p>
          <p class="project-links">
            {p.website && <a href={p.website}>Website</a>}
            {p.repo && <a href={`https://github.com/${p.repo}`}>GitHub</a>}
            {p.blog && <a href={p.blog}>Blog post</a>}
          </p>
        </div>
      ))}
    </div>
  </main>
</Layout>
<style>
  .project-list {
    display: grid;
    gap: 1rem;
    margin: 1.5rem 0;
  }
  .project-card {
    padding: 1rem;
    background: #1f2730;
  }
  .project-card h4 {
    margin: 0;
  }
  .project-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .project-stars {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.85rem;
    color: #cba328;
    white-space: nowrap;
  }
  .project-card p {
    margin: 0.5rem 0;
  }
  .project-card p:last-child {
    margin-bottom: 0;
  }
  .project-links {
    display: flex;
    gap: 1rem;
    font-size: 0.9rem;
  }
</style>
